{
  "version": 1,
  "config": {
    "maxSkillsPerInjection": 3,
    "maxByteBudget": 24000
  },

  "routing": {
    "fileRules": [
      {
        "comment": "SwiftUI view files",
        "pattern": "*View.swift|*Screen.swift|*Page.swift|ContentView*",
        "skills": ["twostraws--swiftui-pro", "dadederk--ios-accessibility"],
        "priority": 10
      },
      {
        "comment": "SwiftUI animation files",
        "pattern": "*Animation*.swift|*Transition*.swift|*Motion*.swift",
        "skills": ["dpearson2699--swiftui-animation", "jordancoin--motioneyes"],
        "priority": 9
      },
      {
        "comment": "SwiftUI navigation files",
        "pattern": "*Router*.swift|*Navigation*.swift|*Coordinator*.swift",
        "skills": ["dpearson2699--swiftui-navigation"],
        "priority": 9
      },
      {
        "comment": "Test files",
        "pattern": "*Tests.swift|*Test.swift|*Spec.swift|*Tests/*",
        "skills": ["twostraws--swift-testing-pro", "avdlee--swift-testing-expert"],
        "priority": 10
      },
      {
        "comment": "SwiftData / Core Data models",
        "pattern": "*Model.swift|*Entity.swift|*.xcdatamodeld*|*Schema*.swift|*Migration*.swift",
        "skills": ["twostraws--swiftdata-pro", "jordancoin--core-data"],
        "priority": 10
      },
      {
        "comment": "Package manifest",
        "pattern": "Package.swift|Package.resolved",
        "skills": ["avdlee--spm-build-analysis", "dpearson2699--swift-language"],
        "priority": 9
      },
      {
        "comment": "Xcode project files",
        "pattern": "*.xcodeproj*|*.pbxproj|*.xcworkspace*|*.xcscheme",
        "skills": ["avdlee--xcode-project-analyzer"],
        "priority": 8
      },
      {
        "comment": "App config and entitlements",
        "pattern": "Info.plist|*.entitlements|PrivacyInfo.xcprivacy",
        "skills": ["truongduy2611--app-store-preflight", "dpearson2699--app-store-review"],
        "priority": 9
      },
      {
        "comment": "Widget extension files",
        "pattern": "*Widget*.swift|*TimelineProvider*.swift|*TimelineEntry*.swift",
        "skills": ["dpearson2699--widgetkit"],
        "priority": 9
      },
      {
        "comment": "App Intent files",
        "pattern": "*Intent*.swift|*AppShortcut*.swift",
        "skills": ["dpearson2699--app-intents"],
        "priority": 9
      },
      {
        "comment": "HealthKit files",
        "pattern": "*HealthKit*.swift|*HealthStore*.swift|*HKQuery*.swift|*HKSample*.swift|*WorkoutSession*.swift",
        "skills": ["dpearson2699--healthkit"],
        "priority": 8
      },
      {
        "comment": "MapKit files",
        "pattern": "*MapKit*.swift|*MapView*.swift|*MKAnnotation*.swift|*MKMapView*.swift|*CLLocation*.swift",
        "skills": ["dpearson2699--mapkit"],
        "priority": 8
      },
      {
        "comment": "StoreKit / IAP files",
        "pattern": "*StoreKit*.swift|*InAppPurchase*.swift|*SKProduct*.swift|*Subscription*.swift|*Paywall*.swift",
        "skills": ["dpearson2699--storekit"],
        "priority": 8
      },
      {
        "comment": "Push notification files",
        "pattern": "*Notification*.swift|*Push*.swift|*UNUser*.swift",
        "skills": ["dpearson2699--push-notifications"],
        "priority": 8
      },
      {
        "comment": "CoreML / Vision / AI files",
        "pattern": "*CoreML*.swift|*MLModel*.swift|*VNRequest*.swift|*VisionKit*.swift|*Prediction*.swift|*FoundationModel*.swift",
        "skills": ["dpearson2699--coreml", "dpearson2699--apple-on-device-ai"],
        "priority": 8
      },
      {
        "comment": "Networking files",
        "pattern": "*Network*.swift|*API*.swift|*Service*.swift|*Client*.swift|*URLSession*.swift",
        "skills": ["dpearson2699--ios-networking"],
        "priority": 7
      },
      {
        "comment": "Authentication files",
        "pattern": "*Auth*.swift|*Login*.swift|*SignIn*.swift|*Credential*.swift",
        "skills": ["dpearson2699--authentication"],
        "priority": 8
      },
      {
        "comment": "Accessibility files",
        "pattern": "*Accessibility*.swift|*A11y*.swift|*VoiceOver*.swift",
        "skills": ["dadederk--ios-accessibility", "pasqualevittoriosi--swift-accessibility"],
        "priority": 9
      },
      {
        "comment": "Bluetooth files",
        "pattern": "*Bluetooth*.swift|*BLE*.swift|*CBCentral*.swift|*CBPeripheral*.swift",
        "skills": ["dpearson2699--core-bluetooth"],
        "priority": 8
      },
      {
        "comment": "CloudKit files",
        "pattern": "*CloudKit*.swift|*CKRecord*.swift|*CKContainer*.swift|*iCloudSync*.swift",
        "skills": ["dpearson2699--cloudkit"],
        "priority": 8
      },
      {
        "comment": "ARKit / RealityKit files",
        "pattern": "*ARView*.swift|*ARSession*.swift|*RealityKit*.swift|*AnchorEntity*.swift|*RealityView*.swift",
        "skills": ["dpearson2699--realitykit"],
        "priority": 8
      },
      {
        "comment": "Liquid Glass / iOS 26 UI",
        "pattern": "*Glass*.swift|*LiquidGlass*.swift|*Glassware*.swift",
        "skills": ["dpearson2699--swiftui-liquid-glass", "harryworld--xcode-26"],
        "priority": 9
      },
      {
        "comment": "UIKit legacy / interop files",
        "pattern": "*ViewController*.swift|*UIKit*.swift|*Representable*.swift",
        "skills": ["dpearson2699--swiftui-uikit-interop", "arimunandar--uikit-layouting"],
        "priority": 7
      },
      {
        "comment": "Localization files",
        "pattern": "*.strings|*.stringsdict|*Localizable*|*.xcstrings|*Localization*.swift",
        "skills": ["dpearson2699--ios-localization"],
        "priority": 8
      },
      {
        "comment": "Security files",
        "pattern": "*Security*.swift|*Keychain*.swift|*Crypto*.swift|*Biometric*.swift",
        "skills": ["dpearson2699--ios-security", "dpearson2699--cryptokit"],
        "priority": 8
      },
      {
        "comment": "Charts files",
        "pattern": "*Chart*.swift|*Graph*.swift|*Plot*.swift",
        "skills": ["dpearson2699--swift-charts"],
        "priority": 8
      },
      {
        "comment": "GameKit / SpriteKit files",
        "pattern": "*GameKit*.swift|*GKMatch*.swift|*SKScene*.swift|*SpriteKit*.swift|*SKSpriteNode*.swift|*GameCenter*.swift",
        "skills": ["dpearson2699--gamekit", "dpearson2699--spritekit"],
        "priority": 8
      },
      {
        "comment": "Background processing files",
        "pattern": "*Background*.swift|*BGTask*.swift|*BackgroundTask*.swift",
        "skills": ["dpearson2699--background-processing"],
        "priority": 8
      },
      {
        "comment": "Photo / Camera files",
        "pattern": "*PhotoKit*.swift|*PHAsset*.swift|*PHPicker*.swift|*CameraCapture*.swift|*PhotoLibrary*.swift",
        "skills": ["dpearson2699--photokit"],
        "priority": 7
      },
      {
        "comment": "Any Swift file — baseline style",
        "pattern": "*.swift",
        "skills": ["jordancoin--swift-style-guide"],
        "priority": 1
      }
    ],

    "bashRules": [
      {
        "comment": "xcodebuild commands",
        "pattern": "xcodebuild",
        "skills": ["jordancoin--xcodebuild-cli", "avdlee--xcode-build-orchestrator"],
        "priority": 10
      },
      {
        "comment": "swift test",
        "pattern": "swift\\s+test",
        "skills": ["avdlee--swift-testing-expert"],
        "priority": 10
      },
      {
        "comment": "swift build",
        "pattern": "swift\\s+build",
        "skills": ["avdlee--spm-build-analysis"],
        "priority": 8
      },
      {
        "comment": "simulator commands",
        "pattern": "xcrun\\s+simctl|simctl",
        "skills": ["jordancoin--xcodebuild-cli"],
        "priority": 9
      },
      {
        "comment": "App Store Connect CLI",
        "pattern": "\\basc\\b|app-store-connect",
        "skills": ["jordancoin--asc-cli", "rudrankriyam--asc-workflow"],
        "priority": 10
      },
      {
        "comment": "fastlane",
        "pattern": "\\bfastlane\\b|\\bgym\\b|\\bdeliver\\b|\\bpilot\\b",
        "skills": ["rudrankriyam--asc-release-flow"],
        "priority": 8
      },
      {
        "comment": "code signing",
        "pattern": "codesign|security\\s+find-identity|provisioning",
        "skills": ["rudrankriyam--asc-signing-setup"],
        "priority": 8
      },
      {
        "comment": "swiftlint",
        "pattern": "swiftlint|swift-format",
        "skills": ["jordancoin--swift-style-guide"],
        "priority": 7
      },
      {
        "comment": "notarization",
        "pattern": "notarytool|xcrun\\s+altool|staple",
        "skills": ["rudrankriyam--asc-notarization"],
        "priority": 9
      },
      {
        "comment": "instruments / profiling",
        "pattern": "\\binstruments\\b|xctrace|leaks\\b|allocations",
        "skills": ["dpearson2699--debugging-instruments"],
        "priority": 9
      },
      {
        "comment": "xcrun general",
        "pattern": "xcrun",
        "skills": ["jordancoin--xcodebuild-cli"],
        "priority": 5
      }
    ]
  },

